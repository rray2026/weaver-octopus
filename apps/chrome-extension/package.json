{
  "name": "@weaver-octopus/chrome-extension",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:dev": "WEAVER_DEV=1 vite build",
    "dev": "vite build --watch",
    "dev:hot": "WEAVER_DEV=1 vite build --watch",
    "dev:logs": "node scripts/dev-log-server.mjs",
    "dev:trigger": "node scripts/dev-trigger.mjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "clean": "rimraf dist *.tsbuildinfo .dev-runtime.log"
  },
  "dependencies": {
    "@weaver-octopus/utils": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.320",
    "@types/node": "^22.0.0",
    "@weaver-octopus/tsconfig": "workspace:*",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.4"
  }
}
