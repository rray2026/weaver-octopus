    "@weaver-octopus/tsconfig": "workspace:*",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.4"
  }
